{
  "name": "jobman",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["backend", "frontend"],
  "scripts": {
    "dev": "concurrently --names \"api,web\" --prefix-colors \"cyan,magenta\" \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build -w frontend",
    "lint": "oxlint --config oxlint.json frontend/src backend",
    "lint:fix": "oxlint --fix --config oxlint.json frontend/src backend",
    "format": "biome format frontend/src backend/*.ts",
    "format:fix": "biome format --write frontend/src backend/*.ts",
    "test": "npm run test --workspaces",
    "tsc": "npm run tsc --workspaces",
    "deploy:backend": "npm run deploy -w backend",
    "deploy:frontend": "npm run deploy -w frontend"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "concurrently": "^8.2.2",
    "oxlint": "^0.16.6"
  }
}
